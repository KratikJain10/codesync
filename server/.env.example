# Server Environment Variables
DATABASE_URL=postgresql://codesync:codesync_secret@localhost:5432/codesync
JWT_SECRET=your-super-secret-jwt-key-change-in-production
CLIENT_URL=http://localhost:3000
PORT=4000
NODE_ENV=development

# Optional: Redis for horizontal scaling (Socket.io adapter, rate limiter, caching)
# REDIS_URL=redis://localhost:6379

# Optional: GitHub OAuth (get from https://github.com/settings/developers)
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
