# =================================
# CodeSync Server — Environment
# =================================

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codesync?schema=public"

# Redis (required for code execution queue)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server
SERVER_PORT=4000
SERVER_URL="http://localhost:4000"
CLIENT_URL="http://localhost:3000"

# GitHub OAuth (optional — leave empty to disable)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Execution Engine
EXECUTION_TIMEOUT=10000
EXECUTION_MEMORY_LIMIT=268435456
